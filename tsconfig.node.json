{
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "outDir": "./out",
    "types": ["electron-vite/node"]
  },
  "include": [
    "electron.vite.config.*",
    "electron/**/*"
  ]
}
